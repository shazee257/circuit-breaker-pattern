{
  "name": "nest-circuit-breaker-microservices",
  "version": "1.0.0",
  "description": "Simple NestJS microservices example demonstrating the circuit breaker pattern.",
  "private": true,
  "scripts": {
    "dev:gateway": "ts-node-dev --respawn --transpile-only apps/api-gateway/src/main.ts",
    "dev:inventory": "ts-node-dev --respawn --transpile-only apps/inventory-service/src/main.ts",
    "dev:payment": "ts-node-dev --respawn --transpile-only apps/payment-service/src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start:gateway": "node dist/api-gateway/src/main.js",
    "start:inventory": "node dist/inventory-service/src/main.js",
    "start:payment": "node dist/payment-service/src/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
